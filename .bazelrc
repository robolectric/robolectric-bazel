common --enable_bzlmod
# Enable WORKSPACE
# TODO: Remove --enable_workspace after all dependencies are migrated to MODULE.bazel
# See https://github.com/bazelbuild/bazel/issues/23023
common --enable_workspace
# Android SDK 36 requires Java 21
common --java_runtime_version=21
# rules_java 8.x pulls in @bazel_features, whose bazel_features_version /
# bazel_features_globals repos hit an autoload cycle under Bazel 8's default
# --incompatible_autoload_externally when building in WORKSPACE mode. Exclude them
# from autoloads. This is a no-op on Bazel 7 and Bazel 9 (autoloads off by default).
# See https://github.com/bazelbuild/bazel/issues/23043
common --repositories_without_autoloads=bazel_features_globals,bazel_features_version
