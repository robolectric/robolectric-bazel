common --enable_bzlmod
# Android SDK 36 requires Java 21
common --java_runtime_version=21
# rules_java 8.x pulls in @bazel_features, which hits an autoload cycle under
# Bazel 8's default autoloads when building in WORKSPACE mode. No-op on Bazel 7/9.
# See https://github.com/bazelbuild/bazel/issues/23043
common --repositories_without_autoloads=bazel_features_globals,bazel_features_version